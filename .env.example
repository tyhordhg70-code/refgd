# ───────────────────────────────────────────────────────────
# Required secrets (set these in your environment / host)
# ───────────────────────────────────────────────────────────

# Render PostgreSQL external connection URL
# Format: postgresql://user:password@host/dbname
RENDER_DATABASE_URL=postgresql://user:password@host/dbname

# Admin authentication
# ADMIN_USERNAME: the username checked at login (default: admin)
ADMIN_USERNAME=admin

# ADMIN_PASSWORD_HASH: bcrypt hash of your admin password — NEVER the plain-text password
# Generate with: node -e "require('bcryptjs').hash('yourpassword',12).then(console.log)"
ADMIN_PASSWORD_HASH=$2a$12$...

# JWT signing secret — min 32 random chars
SESSION_SECRET=replace-with-a-long-random-string-min-32-chars

# ───────────────────────────────────────────────────────────
# Optional / public
# ───────────────────────────────────────────────────────────

# Public site URL (used in OG tags and sitemap)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Admin path slug (default: admin).
# Set to a secret slug to hide /admin behind a custom URL.
# e.g. ADMIN_PATH=secret-control  →  /secret-control = admin,  /admin → 404
ADMIN_PATH=admin

# Server port (defaults to 3000)
PORT=3000
