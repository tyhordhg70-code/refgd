# Auth — change these for production!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme-set-a-strong-password
# 32+ character random string — used to sign admin session cookies
SESSION_SECRET=replace-with-long-random-string-32chars-min

# Database file location (relative to project root)
DB_PATH=./data/refgd.db

# Public site URL (for meta tags, canonical, etc.)
NEXT_PUBLIC_SITE_URL=https://refundgod.io

# Hidden admin slug — change for security through obscurity
ADMIN_PATH=admin

# Server port (defaults to 3000)
PORT=3000
